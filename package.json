{
  "name": "tradeforge",
  "productName": "TradeForge",
  "version": "1.1.0",
  "description": "Automated stock trading desktop app with paper and live modes (Alpaca)",
  "main": "main.js",
  "author": "Chris Korzen",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "smoke": "electron . --smoke",
    "test": "node --test tests/indicators.test.js tests/strategies.test.js",
    "dist": "electron-builder --win && node build/post-dist.js",
    "release": "electron-builder --win --publish always && node build/post-dist.js"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "nodemailer": "^6.9.13"
  },
  "build": {
    "appId": "com.tradeforge.app",
    "productName": "TradeForge",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Korzen101",
      "repo": "TradeForge",
      "releaseType": "release"
    }
  }
}
